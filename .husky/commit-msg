commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

if ! echo "$commit_msg" | grep -qE "EDT-[0-9]+"; then
  echo ""
  echo "🚫 COMMIT REFUSÉ"
  echo "👉 Le message doit contenir une clé Jira"
  echo "✅ Exemple : Feature/EDT-39 initialise frontend project"
  echo ""
  exit 1
fi

# 2️ ESLint
echo ""
echo "🔍 Lancement du lint..."
lint_status=0
npm run lint || lint_status=$?

if [ $lint_status -ne 0 ]; then
  echo ""
  echo "🚫 COMMIT REFUSÉ : erreurs de lint détectées"
  echo "👉 Corrige les erreurs avant de commit"
  exit 1
fi

#
exit 0